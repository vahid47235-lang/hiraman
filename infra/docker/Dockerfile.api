FROM golang:1.23-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build \
    -ldflags="-w -s" \
    -o /bin/hiraban-api \
    ./cmd/api

# ── Runtime ──────────────────────────────────────────────────────────────────
FROM gcr.io/distroless/static-debian12 AS runtime

COPY --from=builder /bin/hiraban-api /hiraban-api

EXPOSE 8080

USER nonroot:nonroot

ENTRYPOINT ["/hiraban-api"]
